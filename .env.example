# Copy this file to .env.mac (recommended — matches device_config.py's
# platform-specific loading) or just .env, then fill in your own values.
# Never commit .env, .env.mac, or .env.jetson — all three are gitignored.
#
# Only the "Required to run the chat app" section below is needed to get
# main.py / chat_app.py running locally on a Mac. Everything else is
# optional and only matters if you're using that specific piece (running
# the ingestion pipeline, tracing to LangSmith, deploying to a Jetson, etc).

# ── Required to run the chat app (main.py / chat_app.py) ────────────────────

# Gemini — used for all agent generation. Get a key at
# https://aistudio.google.com/apikey (AI Studio, simplest path) OR set
# GCP_PROJECT below to use Vertex AI instead (mutually exclusive with this).
GEMINI_API_KEY=

# Tavily — web search fallback (Corrective RAG: used only when nothing in
# the local corpus clears the similarity threshold). Get a free-tier key at
# https://tavily.com
TAVILY_API_KEY=

# ── Optional — Vertex AI instead of AI Studio billing ────────────────────────
# Set GCP_PROJECT to route Gemini calls through Vertex AI (e.g. to use GCP
# free-trial credits) instead of GEMINI_API_KEY. Requires `gcloud auth
# application-default login` locally. Leave both blank to just use
# GEMINI_API_KEY above.
GCP_PROJECT=
GCP_LOCATION=us-central1

# ── Optional — other LLM providers (llm_client.py supports all of these) ────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Ollama needs no key — just a running local server (default http://localhost:11434)

# ── Optional — observability (LangSmith tracing) ─────────────────────────────
# Every agent node is @traceable — set these to see real routing decisions,
# per-node latency, and errors at https://smith.langchain.com instead of
# guessing from logs. Free tier is enough for personal/demo use.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-industry-signals

# ── Optional — content discovery/ingestion pipeline ──────────────────────────
# Only needed if you're running workflows/ingestion.py to grow the corpus,
# not to chat with what's already indexed.
IEEE_API_KEY=
SO_API_KEY=
OPENALEX_API_KEY=
REDUCTO_API_KEY=

# ── Local paths (Mac defaults — device_config.py fills these in automatically
#    if unset, override only if you want a non-default location) ────────────
# DB_PATH=Database/industry_signals_test.db
# DB_PATH_ANALYTICS=Database/industry_signals.db
# DB_BACKEND=duckdb
# MEDIA_DIR=media/
# VECTOR_PATH=Vectors/
# LANCE_VECTOR_PATH=Vectors/lance

# ── Not needed for local Mac use — Jetson production deployment only ─────────
# See CLAUDE.md's "Hardware roles" section. Uncomment and fill in only if
# you're standing up the always-on ingestion server this project was
# originally built against.
# PG_HOST=localhost
# PG_PORT=5432
# PG_DB=industry_signals
# PG_USER=
# PG_PASSWORD=
# JETSON_URL=
# JETSON_IP=
# JETSON_PORT=8000
# JETSON_USER=
